      "optionScore": 71.58,
      "flaggedPromptCount": 0,
      "flaggedOptionCount": 0,
      "items": [
        {
          "id": 1,
          "text": "如果你长期待在一个让自己施展不开的环境里，通常会怎么做？",
          "stemScore": 2.2,
          "note": "把“围墙”从末日隐喻改成长期受限环境，保留破局感但降低世界观压迫。",
          "options": [
            {
              "index": 0,
              "text": "先找突破口，主动争取变化，必要时接受一点风险。",
              "score": 2.4
            },
            {
              "index": 1,
              "text": "先把生活稳住，在现有边界里争取更安全的空间。",
              "score": 1.8
            },
            {
              "index": 2,
              "text": "先摸清规则和资源，再准备更稳妥的转向方案。",
              "score": 2.1
            }
          ]
        },
        {
          "id": 2,
          "text": "当团队资源有限，不可能照顾到每个人时，你更倾向于？",
          "stemScore": 2.4,
          "note": "把极端生命交换改成资源分配，更贴近日常组织困境。",
          "options": [
            {
              "index": 0,
              "text": "优先保住整体目标，即使少数人需要额外承担压力。",
              "score": 2.7
            },
            {
              "index": 1,
              "text": "尽量压低个体损失，不轻易让少数人被迫买单。",
              "score": 1.9
            },
            {
              "index": 2,
              "text": "先把取舍规则讲清楚，让资源分配更透明、更能执行。",
              "score": 2.2
            }
          ]
        },
        {
          "id": 3,
          "text": "你怎么看待一个人的出身和环境对人生的影响？",
          "stemScore": 2,
          "note": "从抽象宿命改成出身与环境影响，戏剧性明显下降。",
          "options": [
            {
              "index": 0,
              "text": "它会限制人，但通常还是留有可以争取的空间。",
              "score": 1.9
            },
            {
              "index": 1,
              "text": "条件再差也不能等它让路，还是要自己闯出路来。",
              "score": 2.3
            },
            {
              "index": 2,
              "text": "先理解资源、规则和概率，再想办法慢慢改写位置。",
              "score": 2.1
            }
          ]
        },
        {
          "id": 4,
          "text": "如果你和曾经非常信任的人在关键问题上立场相反，你通常会？",
          "stemScore": 2.3,
          "note": "保留关系冲突，但不再直接上升到战场背叛。",
          "options": [
            {
              "index": 0,
              "text": "如果事情已经无法回避，我会做决定，但会记住后果。",
              "score": 2.5
            },
            {
              "index": 1,
              "text": "先争取沟通，尽量为彼此留一条还能回头的路。",
              "score": 1.8
            },
            {
              "index": 2,
              "text": "先确保重要的人不被波及，再决定接下来怎么处理。",
              "score": 2
            }
          ]
        },
        {
          "id": 5,
          "text": "更能长期支撑你行动的，通常是什么？",
          "stemScore": 1.6,
          "note": "保留价值观题结构，但把三条驱动力写得更像真实会牵引人的执念。",
          "options": [
            {
              "index": 0,
              "text": "哪怕代价高一点，也想把方向和选择权握在自己手里。",
              "score": 2.4
            },
            {
              "index": 1,
              "text": "嘴上可以说算了，但真正牵着我走的，往往还是那几个人和那点执念。",
              "score": 2.3
            },
            {
              "index": 2,
              "text": "只要还有人等我扛事，我就很难真正停下来。",
              "score": 2.2
            }
          ]
        },
        {
          "id": 6,
          "text": "如果一件你投入很多的事大概率会失败，最后阶段你会？",
          "stemScore": 2.1,
          "note": "从世界末日改成高投入事项大概率失败，保留收尾方式差异。",
          "options": [
            {
              "index": 0,
              "text": "还是会继续尝试，看能不能再多争取一点空间。",
              "score": 2.4
            },
            {
              "index": 1,
              "text": "接受结果，但把收尾、交接和影响控制好。",
              "score": 2.1
            },
            {
              "index": 2,
              "text": "把时间留给重要的人，也尽量让过程体面一些。",
              "score": 1.8
            }
          ]
        },
        {
          "id": 7,
          "text": "你怎么看待“善意的隐瞒”？",
          "stemScore": 1.5,
          "note": "维持常见伦理题框架，但让“设期限 / 说开 / 自己背锅”三种姿态更分明。",
          "options": [
            {
              "index": 0,
              "text": "只会在局面快失控时短暂压住消息，但会提前想好何时交代、怎么收尾。",
              "score": 2.1
            },
            {
              "index": 1,
              "text": "宁可一开始难堪一点，我也更想把话说开，免得以后信任整块塌掉。",
              "score": 2.2
            },
            {
              "index": 2,
              "text": "如果能替具体的人挡掉一波伤害，我愿意自己背这个隐瞒。",
              "score": 2.4
            }
          ]
        },
        {
          "id": 8,
          "text": "如果一个真相可能打乱你现有生活，你还会想知道吗？",
          "stemScore": 1.9,
          "note": "从崩溃级真相改成可能打乱生活的事实，温度更低。",
          "options": [
            {
              "index": 0,
              "text": "会，不知道反而更难真正做选择。",
              "score": 2
            },
            {
              "index": 1,
              "text": "会看时机，有些事需要准备好再面对。",
              "score": 1.8
            },
            {
              "index": 2,
              "text": "会想知道，但也会预留消化和协商空间。",
              "score": 2
            }
          ]
        },
        {
          "id": 9,
          "text": "如果你突然掌握了远超常人的资源或影响力，你更可能？",
          "stemScore": 2,
          "note": "把毁天灭地力量改成资源与影响力，减少奇观感。",
          "options": [
            {
              "index": 0,
              "text": "会把它当成底牌，但不想让它变成唯一的解决方式。",
              "score": 2.1
            },
            {
              "index": 1,
              "text": "先限制使用边界，尽量避免影响外溢。",
              "score": 1.9
            },
            {
              "index": 2,
              "text": "把它当成长期博弈的筹码，换更稳定的合作空间。",
              "score": 2.2
            }
          ]
        },
        {
          "id": 10,
          "text": "在团队里，大家通常会自然把什么事交给你？",
          "stemScore": 1.7,
          "note": "团队角色题适度回调戏剧性，强化拍板者、收残局者与唱反调者的区别。",
          "options": [
            {
              "index": 0,
              "text": "需要看清局势、调配资源、把优先级定下来的时候，通常会先找到我。",
              "score": 2.5
            },
            {
              "index": 1,
              "text": "真要把事情做完、把漏洞补上、把代价算清的时候，通常是我去收。",
              "score": 2.3
            },
            {
              "index": 2,
              "text": "当大家都顺着惯性往前冲时，我会先把那个最刺耳的反对意见说出来。",
              "score": 2.6
            }
          ]
        },
        {
          "id": 11,
          "text": "如果你的某种身份或处境会让身边人跟着承担风险，你通常会？",
          "stemScore": 2,
          "note": "保留身份压力，但从灾难语气改成风险传导。",
          "options": [
            {
              "index": 0,
              "text": "知道这层风险躲不掉时，我会先隔离它，再把距离拉开，避免继续波及身边人。",
              "score": 2.1
            },
            {
              "index": 1,
              "text": "会说明情况，再和相关的人一起定方案。",
              "score": 1.8
            },
            {
              "index": 2,
              "text": "不想被身份完全定义，但会更谨慎安排自己的选择。",
              "score": 2
            }
          ]
        },
        {
          "id": 12,
          "text": "一个曾和你立场相反、甚至伤过你的人主动求助，你会？",
          "stemScore": 2.3,
          "note": "把敌对阵营孩子改成曾对立且伤过你的人，仍有伦理张力但更常见。",
          "options": [
            {
              "index": 0,
              "text": "会先帮他脱离当下困境，再处理之后的界限。",
              "score": 2
            },
            {
              "index": 1,
              "text": "会帮，但会同时评估风险并留一点后手。",
              "score": 2.1
            },
            {
              "index": 2,
              "text": "如果这会明显拖累更多人，我会优先顾全整体责任。",
              "score": 2.4
            }
          ]
        },
        {
          "id": 13,
          "text": "为了避免恐慌，上级希望暂时不公开全部信息，你更倾向于？",
          "stemScore": 2.1,
          "note": "信息公开题保留治理意味，但不再过于战时。",
          "options": [
            {
              "index": 0,
              "text": "先配合稳定局面，同时尽快安排后续公开节奏。",
              "score": 2.2
            },
            {
              "index": 1,
              "text": "部分公开，保留关键筹码，避免全面失控。",
              "score": 2
            },
            {
              "index": 2,
              "text": "尽量多公开，让人至少保有基本判断空间。",
              "score": 2.1
            }
          ]
        },
        {
          "id": 14,
          "text": "如果追究一段旧怨能让你出气，但会让关系更糟，你会？",
          "stemScore": 1.9,
          "note": "仍是旧怨处理，但把“硬算账 / 强停手 / 留到谈判桌”三种处理方式写得更有张力。",
          "options": [
            {
              "index": 0,
              "text": "我大概率还是会把这笔账算清，哪怕知道算完以后关系会更僵。",
              "score": 2.5
            },
            {
              "index": 1,
              "text": "会强迫自己把事停在这里，至少别让更多无关的人被卷进后续消耗。",
              "score": 2
            },
            {
              "index": 2,
              "text": "先把情绪封住，不急着翻旧账，而是留到更能谈条件、谈代价的时候再处理。",
              "score": 2.3
            }
          ]
        },
        {
          "id": 15,
          "text": "哪种状态最让你坐立不安？",
          "stemScore": 1.7,
          "note": "不可忍受状态题，整体中性。",
          "options": [
            {
              "index": 0,
              "text": "人生方向总被别人安排，自己几乎没有选择空间。",
              "score": 1.9
            },
            {
              "index": 1,
              "text": "因为自己的软弱而拖累同伴。",
              "score": 1.8
            },
            {
              "index": 2,
              "text": "一个本可避免的失误，害很多人去承担后果。",
              "score": 1.9
            }
          ]
        },
        {
          "id": 16,
          "text": "如果给团队树一个简单靶子，能短时间凝聚共识，你会？",
          "stemScore": 2.4,
          "note": "保留“树靶子”这个操盘意味，但语气从战争宣传降为团队策略。",
          "options": [
            {
              "index": 0,
              "text": "只在别无选择时考虑，但不想让真实完全退场。",
              "score": 2.5
            },
            {
              "index": 1,
              "text": "非常时期可以做，但由我自己承担这个做法的污名。",
              "score": 2.4
            },
            {
              "index": 2,
              "text": "不会，靠简化敌人换来的团结通常后患更大。",
              "score": 2.1
            }
          ]
        },
        {
          "id": 17,
          "text": "当现场气氛越来越乱、大家都开始着急时，你通常会？",
          "stemScore": 1.6,
          "note": "仍是常见混乱场景，但选项语气更鲜明：强行刹车、重建秩序、先护住核心。",
          "options": [
            {
              "index": 0,
              "text": "会先明确叫停，哪怕语气重一点，也要把混乱先刹住。",
              "score": 2.3
            },
            {
              "index": 1,
              "text": "会把人一个个拉回步骤里，先重建秩序，再谈情绪。",
              "score": 2
            },
            {
              "index": 2,
              "text": "会先守住自己和最重要的人，确认不会一起失控，再看要不要接场。",
              "score": 2.2
            }
          ]
        },
        {
          "id": 18,
          "text": "如果你提前收到一些不完整、但可能准确的预警信息，你会？",
          "stemScore": 1.8,
          "note": "未来片段降级为不完整预警信息，更贴近日常决策。",
          "options": [
            {
              "index": 0,
              "text": "会先按最坏情况把后手和空位预留出来，但不会完全照着这份预警行动。",
              "score": 1.9
            },
            {
              "index": 1,
              "text": "把它当作情报，尽可能改写最坏结果。",
              "score": 1.8
            },
            {
              "index": 2,
              "text": "不希望被预警绑住，还是想保留当下的主动权。",
              "score": 1.9
            }
          ]
        },
        {
          "id": 19,
          "text": "当你发现自己做错了一件影响不小的事，你通常会？",
          "stemScore": 1.7,
          "note": "错误处理题回调少量戏剧性，让“先扛住 / 先认错 / 先切断损失”更有辨识度。",
          "options": [
            {
              "index": 0,
              "text": "先把最危险的连锁反应压住，哪怕那一刻得由我先把后果顶下来。",
              "score": 2.2
            },
            {
              "index": 1,
              "text": "会立刻叫停并认错，宁可难堪，也不想让错继续滚大。",
              "score": 2.1
            },
            {
              "index": 2,
              "text": "先拆开责任链，冷静复盘，把后续能断的损失先断掉。",
              "score": 2
            }
          ]
        },
        {
          "id": 20,
          "text": "你更相信什么最能推动长期改变？",
          "stemScore": 1.6,
          "note": "长期改变题适度加入立场感，把守线、说服、硬撑三种信念重新拉开。",
          "options": [
            {
              "index": 0,
              "text": "有人死死守住不退，让别人知道这条线不会被轻易改写。",
              "score": 2.4
            },
            {
              "index": 1,
              "text": "让更多人真正被说服、愿意一起走，而不是只被一时推着走。",
              "score": 2
            },
            {
              "index": 2,
              "text": "不是每次都赢，而是很多次快撑不住时，还是有人能继续活下来。",
              "score": 2.3
            }
          ]
        }
